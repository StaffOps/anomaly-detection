{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Controller Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "staffops_ad_controller_is_leader",
          "legendFormat": "Leader",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "ACTIVE", "color": "green" },
                "0": { "text": "STANDBY", "color": "yellow" }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Detection Cycles/min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "targets": [
        {
          "expr": "rate(staffops_ad_controller_cycles_total{status=\"success\"}[5m]) * 60",
          "legendFormat": "cycles/min",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Anomalies/min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(staffops_ad_detection_anomalies_total[5m])) * 60",
          "legendFormat": "anomalies/min",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 10, "color": "yellow" },
              { "value": 50, "color": "red" }
            ]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Alerts Fired/min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(staffops_ad_alert_fired_total[5m])) * 60",
          "legendFormat": "alerts/min",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Workers Available",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "staffops_ad_controller_workers_available",
          "legendFormat": "workers",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": { "text": "UP", "color": "green" },
                "0": { "text": "DOWN", "color": "red" }
              }
            }
          ]
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Dedup/min",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "expr": "rate(staffops_ad_alert_deduplicated_total[5m]) * 60",
          "legendFormat": "dedup/min",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Anomalies by Signal",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(staffops_ad_detection_anomalies_total[5m])) by (signal) * 60",
          "legendFormat": "{{signal}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20 }, "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Anomalies by Severity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(staffops_ad_detection_anomalies_total[5m])) by (severity) * 60",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "fillOpacity": 20 }, "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "critical" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "title": "Cycle Duration P95/P50",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(staffops_ad_controller_cycle_duration_seconds_bucket[5m]))",
          "legendFormat": "P95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, rate(staffops_ad_controller_cycle_duration_seconds_bucket[5m]))",
          "legendFormat": "P50",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "Worker Job Duration P95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(staffops_ad_worker_job_duration_seconds_bucket[5m])) by (le, type))",
          "legendFormat": "{{type}} P95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "Query Duration by Datasource P95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(staffops_ad_worker_query_duration_seconds_bucket[5m])) by (le, datasource))",
          "legendFormat": "{{datasource}} P95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    },
    {
      "title": "Query Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "sum(rate(staffops_ad_worker_query_errors_total[5m])) by (datasource) * 60",
          "legendFormat": "{{datasource}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "axisLabel": "errors/min" } },
        "overrides": []
      }
    },
    {
      "title": "Baseline Series Tracked",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "sum(staffops_ad_worker_baseline_series_tracked)",
          "legendFormat": "series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "title": "Redis Ops & Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "sum(rate(staffops_ad_worker_redis_operations_total[5m])) * 60",
          "legendFormat": "ops/min",
          "refId": "A"
        },
        {
          "expr": "sum(rate(staffops_ad_worker_redis_errors_total[5m])) * 60",
          "legendFormat": "errors/min",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "errors/min" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "title": "K8s Events Received",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "targets": [
        {
          "expr": "sum(rate(staffops_ad_worker_events_received_total[5m])) by (reason) * 60",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "Detections by Detector Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 36 },
      "targets": [
        {
          "expr": "sum(rate(staffops_ad_worker_detections_total[5m])) by (detector) * 60",
          "legendFormat": "{{detector}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "fillOpacity": 10 } },
        "overrides": []
      }
    },
    {
      "title": "Cardinality Watch",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 44 },
      "targets": [
        {
          "expr": "topk(15, count by (__name__) ({__name__=~\"staffops_ad_.+\"}))",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true },
            "renameByName": { "__name__": "metric", "Value": "series_count" }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "series_count" },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    { "value": null, "color": "green" },
                    { "value": 500, "color": "yellow" },
                    { "value": 1000, "color": "orange" },
                    { "value": 2000, "color": "red" }
                  ]
                }
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": { "sortBy": [{ "displayName": "series_count", "desc": true }] }
    },
    {
      "title": "Recent Alerts (Loki)",
      "type": "table",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 44 },
      "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
      "targets": [
        {
          "expr": "{service=\"controller\"} | json | msg=\"alert_fired\"",
          "legendFormat": "",
          "refId": "A",
          "maxLines": 50
        }
      ],
      "transformations": [
        {
          "id": "extractFields",
          "options": { "source": "Line", "format": "json" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "id": true, "tsNs": true, "labels": true, "Line": true },
            "renameByName": {
              "ts": "time",
              "severity": "severity",
              "namespace": "namespace",
              "workload": "workload",
              "signal": "signal",
              "msg": "message"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "severity" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "critical": { "color": "red", "text": "critical" }, "warning": { "color": "orange", "text": "warning" }, "info": { "color": "blue", "text": "info" } } }
                ]
              },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "options": { "showHeader": true }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["staffops-ad", "anomaly-detection"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "staffops-ad / System Health",
  "uid": "staffops-ad-system-health"
}
