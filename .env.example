# =============================================================================
# staffops-anomaly-detection — environment variables (12-factor: III. Config)
#
# Copy to `.env` and fill values. The docker-compose stack auto-loads `.env`
# from the same directory as the compose file (scripts/.env).
# =============================================================================

# --- Cluster identity ---
# CLUSTER_NAME: the kubernetes cluster name (matches kubernetes-mixin convention).
# Becomes the `cluster` constant label on every metric.
#
# Additional org-specific labels (eks_cluster, environment, team, etc.) belong
# at the scrape layer — set them in vmagent externalLabels (production) or
# scripts/observability/prometheus.yml `external_labels` (local). The app
# stays generic; this is the same separation-of-concerns rule as
# observability-principles.md (SDK emits service identity; Collector enriches).
CLUSTER_NAME=my-cluster

# --- Datasources (REQUIRED — no defaults) ---
VM_URL=https://victoria-metrics-read.example.com/select/0/prometheus
LOKI_URL=https://loki.example.com
ALERTMANAGER_URL=https://alertmanager.example.com

# --- Datasource timeouts (optional, defaults shown) ---
VM_TIMEOUT=30s
LOKI_TIMEOUT=30s

# --- Redis (optional, defaults shown) ---
REDIS_ADDR=redis:6379
REDIS_DB=0
REDIS_PASSWORD=

# --- ML service (optional, defaults shown) ---
ML_ENDPOINT=ml:50051
ML_ENABLED=true
ML_TIMEOUT=5s

# --- Controller (optional, defaults shown) ---
CONTROLLER_LEASE_NAMESPACE=monitoring
WORKER_ENDPOINT=dns:///worker:50052

# --- Alert deep-link bases (optional — empty = annotation not emitted) ---
GRAFANA_BASE_URL=https://grafana.example.com
TEMPO_BASE_URL=https://grafana.example.com
LOKI_BASE_URL=https://grafana.example.com
RUNBOOK_BASE_URL=https://docs.example.com/runbooks/anomaly-detection

# --- Grafana datasource UIDs (optional — needed for one-click links) ---
GRAFANA_VM_DATASOURCE_UID=
GRAFANA_TEMPO_DATASOURCE_UID=
GRAFANA_LOKI_DATASOURCE_UID=

# --- Suppression (organization-specific noisy namespaces) ---
# Regex for namespaces excluded from ALL detection queries (built into PromQL)
EXCLUDE_NAMESPACES_REGEX=kube-system

# Comma-separated list — fully suppressed (no detection at all)
EXCLUDE_NAMESPACES_CSV=kube-system

# Comma-separated list — static threshold suppressed; adaptive still fires
# (use for batch/cron namespaces with unpredictable workload)
EXCLUDE_STATIC_ONLY_CSV=
